mperature": 0.0, "avg_logprob": -0.20195875329486393, "compression_ratio": 1.4277456647398843, "no_speech_prob": 2.0125784719327022e-12}, {"id": 748, "seek": 308820, "start": 3088.2, "end": 3089.66, "text": " Yeah, think about them.", "tokens": [50365, 865, 11, 519, 466, 552, 13, 50438], "temperature": 0.0, "avg_logprob": -0.14337044292026097, "compression_ratio": 1.5123152709359606, "no_speech_prob": 2.3896093437336674e-12}, {"id": 749, "seek": 308820, "start": 3089.66, "end": 3104.3199999999997, "text": " If fliction is right, and meaning only truly exists in the paths we actively walk, what digital roads in your own mind are you letting wash away right now simply because you falsely believe the knowledge is safely stored?", "tokens": [50438, 759, 932, 4105, 307, 558, 11, 293, 3620, 787, 4908, 8198, 294, 264, 14518, 321, 13022, 1792, 11, 437, 4562, 11344, 294, 428, 1065, 1575, 366, 291, 8295, 5675, 1314, 558, 586, 2935, 570, 291, 16720, 736, 1697, 264, 3601, 307, 11750, 12187, 30, 51171], "temperature": 0.0, "avg_logprob": -0.14337044292026097, "compression_ratio": 1.5123152709359606, "no_speech_prob": 2.3896093437336674e-12}, {"id": 750, "seek": 308820, "start": 3105.7799999999997, "end": 3107.3599999999997, "text": " Keep walking the paths.", "tokens": [51244, 5527, 4494, 264, 14518, 13, 51323], "temperature": 0.0, "avg_logprob": -0.14337044292026097, "compression_ratio": 1.5123152709359606, "no_speech_prob": 2.3896093437336674e-12}, {"id": 751, "seek": 308820, "start": 3108.3199999999997, "end": 3110.16, "text": " Thanks for diving deep with us today.", "tokens": [51371, 2561, 337, 20241, 2452, 365, 505, 965, 13, 51463], "temperature": 0.0, "avg_logprob": -0.14337044292026097, "compression_ratio": 1.5123152709359606, "no_speech_prob": 2.3896093437336674e-12}], "language": "en"} -> {"text": " Imagine, if you will, a library burning down. Oh, man. Right. It's just this universally understood catastrophe. Yeah. You've got the smoke, the flames, just the sheer deva
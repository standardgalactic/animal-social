.4831932773109244, "no_speech_prob": 1.0260975229214875e-11}, {"id": 430, "seek": 182872, "start": 1835.6000000000001, "end": 1836.8600000000001, "text": " D\u00e1 aquela sensa\u00e7\u00e3o de", "tokens": [50709, 49794, 25996, 2923, 6670, 368, 50772], "temperature": 0.0, "avg_logprob": -0.14721986452738445, "compression_ratio": 1.4831932773109244, "no_speech_prob": 1.0260975229214875e-11}, {"id": 431, "seek": 182872, "start": 1836.8600000000001, "end": 1838.3600000000001, "text": " Ah, eu baixei o livro,", "tokens": [50772, 2438, 11, 2228, 40447, 17067, 277, 33545, 11, 50847], "temperature": 0.0, "avg_logprob": -0.14721986452738445, "compression_ratio": 1.4831932773109244, "no_speech_prob": 1.0260975229214875e-11}, {"id": 432, "seek": 182872, "start": 1838.82, "end": 1840.3600000000001, "text": " ent\u00e3o eu j\u00e1 sei sobre o assunto.", "tokens": [50870, 9071, 2228, 6242, 10842, 5473, 277, 50219, 13, 50947], "temperature": 0.0, "avg_logprob": -0.14721986452738445, "compression_ratio": 1.4831932773109244, "no_speech_prob": 1.0260975229214875e-11}, {"id": 433, "seek": 182872, "start": 1840.64, "end": 1840.92, "text": " Sabe?", "tokens": [50961, 318, 4488, 30, 50975], "temperature": 0.0, "avg_logprob": -0.14721986452738445, "compression_ratio": 1.4831932773109244, "no_speech_prob": 1.0260975229214875e-11}, {"id": 434, "seek": 182872, "start": 1841.3600000000001, "end": 1844.6000000000001, "text": " O que garante a utilidade da informa\u00e7\u00e3o amanh\u00e3", "tokens": [50997, 422, 631, 3691, 2879, 257, 4976, 6014, 1120, 48403, 42943, 36320, 51159], "temperature": 0.0, "avg_logprob": -0.14721986452738445, "compression_ratio": 1.4831932773109244, "no_speech_prob": 1.0260975229214875e-11}, {"id": 435, "seek": 182872, "start": 1844.6000000000001, "end": 1847.88, "text": " \u00e9 a velocidade e a precis\u00e3o", "tokens": [51159, 1136, 257, 45181, 308, 257, 7974, 1076, 51323], "temperature": 0.0, "avg_logprob": -0.14721986452738445, "compression_ratio": 1.48319327731